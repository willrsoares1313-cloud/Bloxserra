            padding: 5px;
        }
        /* BANNER PRINCIPAL */
        .banner {
            background-image: linear-gradient(to right, #ffcc00, #ff6600);
            padding: 40px;
            text-align: center;
            margin: 20px auto;
            max-width: 1200px;
        }
        .banner h1 {
            font-size: 36px;
            margin-bottom: 20px;
            text-shadow: 2px 2px #000;
            color: #fff;
