            margin: 30px auto;
            padding: 20px;
            background-color: #fff;
        }
        .section h2 {
            color: #8b0000;
            margin-bottom: 15px;
            border-bottom: 3px solid #ffcc00;
        }
        .personagens {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-top: 20px;
        }
        .personagem-card {
            background-color: #f8f1e0;
            padding: 10px;
            text-align: center;
            width: 200px;
        }
        /* RODAPÉ */
        footer {
            background-color: #8b0000;
            color: #fff;
            text-align: center;
            padding: 20px;
            margin-top: 30px;
        }
